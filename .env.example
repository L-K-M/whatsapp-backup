WEB_PORT=64009
# Host base directory. Plain-text message records are written to DATA_PATH/archive.
# Compose mounts the base directory so fresh installs do not depend on a pre-created archive subdirectory.
# The chmod-sensitive wacli session store uses a Docker named volume instead.
DATA_PATH=./data
TZ=UTC

# wacli source used at image build time.
WACLI_REPO=https://github.com/steipete/wacli.git
WACLI_REF=main

# Runtime behavior.
AUTO_SYNC=1
EXPORT_INTERVAL_SECONDS=60
SUPERVISOR_INTERVAL_SECONDS=15
MAX_PROCESS_LOG_LINES=600
WACLI_DEVICE_LABEL=WhatsApp Backup

# WhatsApp connection safety. wacli handles reconnects internally; if it exits,
# the wrapper waits with exponential backoff before starting a new sync process.
SYNC_MAX_RECONNECT=30m
SYNC_RESTART_MIN_SECONDS=300
SYNC_RESTART_MAX_SECONDS=3600
SYNC_STABLE_SECONDS=300

# Optional SMTP outage alerts. All SMTP_* values except password are shown in
# the UI status. SMTP_PASSWORD is only passed to the backend process.
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_TO=
SMTP_USE_TLS=1
SMTP_USE_SSL=0
SMTP_TIMEOUT_SECONDS=20
SMTP_SUBJECT_PREFIX=[WhatsApp Backup]
